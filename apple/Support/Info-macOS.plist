<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>LiAuth</string>
    <key>CFBundleName</key>
    <string>LiAuth</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>ATSApplicationFontsPath</key>
    <string>.</string>
    <key>NSCameraUsageDescription</key>
    <string>LiAuth uses the camera only to scan QR codes. Nothing is recorded.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>LiAuth uses the local network only to move your accounts between your own devices.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_liauth._tcp</string>
    </array>
</dict>
</plist>
